# ─── ParkIt UCC · Variables de entorno ───────────────────────────────────────
# Copiá este archivo como .env y completá los valores.
# Las variables EXPO_PUBLIC_* quedan expuestas en el bundle del cliente.
# Nunca subas .env al repositorio.

# ── Supabase (producción / staging) ──────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Supabase local (desarrollo con supabase start) ────────────────────────────
# Descomentá estos y comentá los de arriba para trabajar contra la instancia local.
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd7LFpnBskFzmO9Su_oxv7pmpSPMSBkM

# ── Tests de integración (opcional — solo para run-all-tests.sh con Supabase) ─
# Si usás una URL/key distintas para testing, sobreescribí acá.
# SUPABASE_TEST_URL=http://127.0.0.1:54321
# SUPABASE_TEST_ANON_KEY=<anon-key-local>
# SUPABASE_TEST_SERVICE_KEY=<service-role-key-local>
