{
  "expo": {
    "name": "ParkIt UCC",
    "slug": "parkit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ucc.parkit",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para mostrarte tu posición en el mapa del campus y ayudarte a encontrar el estacionamiento más cercano.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Para mostrarte tu posición en el mapa del campus."
      }
    },
    "android": {
      "package": "com.ucc.parkit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "TU_API_KEY_AQUI"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "scheme": "parkit",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-maps"
    ]
  }
}
